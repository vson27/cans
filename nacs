#include <stdio.h>
#include <string.h>
#include <stdlib.h>

typedef struct {
    char name[20];
    int priority;
} UserRequest;

int main(int argc, char *argv[]) {

    if (argc < 3) {
        printf("Usage: %s <name> <description>\n", argv[0]);
        return 1;
    }

    UserRequest *req = malloc(sizeof(UserRequest));
    char *description = malloc(20);

    req->priority = 1;

    strcpy(req->name, "Guest");

    strcpy(description, argv[1]);

    strncpy(req->name, argv[2], 19);

    printf("Description: %s\n", description);
    printf("User: %s\n", req->name);
    printf("Priority Level: %d\n", req->priority);

    if (req->priority == 99) {
        printf(">> ADMIN ACCESS GRANTED <<\n");
