Exercise 1 — Stack Overflow (Variable Corruption)
File: stack_var.c
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int main(int argc, char *argv[]) {
    int secret_pass = 0;
    char buffer[16];

    if (argc < 2) {
        printf("Usage: %s <input_string>\n", argv[0]);
        return 1;
    }

    strcpy(buffer, argv[1]);

    printf("Buffer content: %s\n", buffer);
    printf("Secret Pass Value: %d\n", secret_pass);

    if (secret_pass != 0) {
        printf("SUCCESS! You have corrupted the variable and bypassed the check!\n");
    } else {
        printf("Failed. Secret pass is still 0.\n");
    }

    return 0;
}
Compile
