Merkle Tree Python Implementation
File: merkle_tree.py
import hashlib
import os


def sha1(data):
    return hashlib.sha1(data).digest()


def build_merkle(files):
    level = []

    for file in files:
        with open(file, 'rb') as f:
            level.append(sha1(f.read()))

    tree = [level]

    while len(level) > 1:
        new_level = []

        for i in range(0, len(level), 2):
            left = level[i]

            if i + 1 < len(level):
                right = level[i+1]
            else:
                right = b''

            new_level.append(sha1(left + right))

        tree.append(new_level)
        level = new_level

    return tree


files = ['doc0.dat', 'doc1.dat', 'doc2.dat']

root = build_merkle(files)[-1][0]

print(root.hex())
